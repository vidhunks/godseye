# ============================
# Application
# ============================
APP_NAME=GodsEye
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=False

# ============================
# Server
# ============================
HOST=127.0.0.1
PORT=8000

# ============================
# Neo4j (required)
# ============================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ============================
# PostgreSQL (optional)
# ============================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=godseye
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ============================
# Redis (optional)
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================
# RabbitMQ (optional)
# ============================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
